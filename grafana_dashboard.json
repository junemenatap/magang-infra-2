{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Select the Prometheus data source already used by your beyla-frontend/beyla-backend panels",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "title": "eBPF Kernel-Level TCP Observability",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "browser",
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "TCP Connect Latency (p50 / p95 / p99) by process",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.50, sum(rate(ebpf_tcp_connect_latency_seconds_bucket[5m])) by (le, comm))",
          "legendFormat": "p50 {{comm}}",
          "refId": "A"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.95, sum(rate(ebpf_tcp_connect_latency_seconds_bucket[5m])) by (le, comm))",
          "legendFormat": "p95 {{comm}}",
          "refId": "B"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.99, sum(rate(ebpf_tcp_connect_latency_seconds_bucket[5m])) by (le, comm))",
          "legendFormat": "p99 {{comm}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 2,
      "title": "TCP Retransmissions per second, by process and destination",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(ebpf_tcp_retransmits_total[1m])) by (comm, daddr)",
          "legendFormat": "{{comm}} -> {{daddr}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Connections Closed per second",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(ebpf_tcp_connections_closed_total[1m])) by (comm)",
          "legendFormat": "{{comm}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Exporter Health: parse errors (5m)",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "increase(ebpf_exporter_parse_errors_total[5m])",
          "refId": "A"
        }
      ]
    }
  ]
}
