{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "The Prometheus data source already scraping beyla-frontend/backend in your stack",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "heatmap",
      "name": "Heatmap",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": "1.0.0"
    }
  ],
  "title": "eBPF bcc Tools (Cloudflare ebpf_exporter)",
  "description": "Metrics from biolatency and cachestat, running via ghcr.io/cloudflare/ebpf_exporter alongside the Beyla demo stack.",
  "tags": [
    "ebpf",
    "bcc",
    "beyla-demo"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Exporter Scrape Health",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "up{job=\"ebpf-bcc-exporter\"}",
          "legendFormat": "ebpf-bcc-exporter",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Block IO Latency Heatmap (biolatency)",
      "type": "heatmap",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Raw distribution of block IO completion latency, from block_rq_insert/issue/complete tracepoints.",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "sum(rate(ebpf_exporter_bio_latency_seconds_bucket[1m])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": {
          "unit": "s",
          "axisLabel": "latency"
        },
        "color": {
          "mode": "scheme",
          "scheme": "Spectral",
          "reverse": false
        }
      }
    },
    {
      "id": 3,
      "title": "Block IO Latency p50 / p95 / p99 (by device, operation)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ebpf_exporter_bio_latency_seconds_bucket[5m])) by (le, device, operation))",
          "legendFormat": "p50 {{device}}/{{operation}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ebpf_exporter_bio_latency_seconds_bucket[5m])) by (le, device, operation))",
          "legendFormat": "p95 {{device}}/{{operation}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ebpf_exporter_bio_latency_seconds_bucket[5m])) by (le, device, operation))",
          "legendFormat": "p99 {{device}}/{{operation}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "Page Cache Operations Rate (cachestat)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "cache_access / cache_writes / page_add_lru / page_mark_dirties per second.",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "expr": "sum(rate(ebpf_exporter_page_cache_ops_total[1m])) by (operation)",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      }
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  }
}